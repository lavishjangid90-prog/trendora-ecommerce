# Trendora environment variables
#
# Backend variables are used by the Express server. Copy this file to:
# backend/.env.local
#
# Example:
# cp .env.example backend/.env.local

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_gemini_api_key"

# APP_URL: The URL where this app is hosted.
APP_URL="https://your-app.example.com"

# MongoDB Database Connection String
MONGODB_URI="mongodb+srv://username:password@cluster.example.mongodb.net/trendora?retryWrites=true&w=majority"

# Razorpay Keys
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# JWT Secret for authentication
JWT_SECRET="replace_with_a_long_random_secret"
