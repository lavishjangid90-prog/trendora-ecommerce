{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://trendora-ecommerce-e5zp.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://trendora-ecommerce-e5zp.onrender.com/uploads/$1"
    },
    {
      "source": "/((?!robots.txt|sitemap.xml|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
